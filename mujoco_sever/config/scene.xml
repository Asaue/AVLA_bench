<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <mesh name="silver_bowl_mesh" file="silver_bowl.obj"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_wood" rgba="0.55 0.42 0.28 1" reflectance="0.15"/>
    <material name="bowl_silver" rgba="0.80 0.82 0.86 1" reflectance="0.45" specular="0.95" shininess="0.9"/>
    <material name="plate_white" rgba="0.94 0.95 0.97 1" reflectance="0.3"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <camera name="cam_global" pos="1.45 -1.30 1.10"
      xyaxes="0.707 0.707 0.000 -0.242 0.242 0.940" fovy="60"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="work_table" pos="0.68 0 0">
      <geom name="table_top" type="box" pos="0 0 0.39" size="0.36 0.32 0.03" material="table_wood"/>
      <geom name="table_leg_fl" type="box" pos="0.29 0.25 0.18" size="0.03 0.03 0.18" material="table_wood"/>
      <geom name="table_leg_fr" type="box" pos="0.29 -0.25 0.18" size="0.03 0.03 0.18" material="table_wood"/>
      <geom name="table_leg_rl" type="box" pos="-0.29 0.25 0.18" size="0.03 0.03 0.18" material="table_wood"/>
      <geom name="table_leg_rr" type="box" pos="-0.29 -0.25 0.18" size="0.03 0.03 0.18" material="table_wood"/>
    </body>

    <body name="cup_target" pos="0.45 0.00 0.525">
      <freejoint name="cup_target_freejoint"/>
      <inertial pos="0 0 0" mass="0.15" fullinertia="0.0002 0.0002 0.0001 0 0 0"/>
      
      <geom name="cup_body" type="box" size="0.025 0.025 0.04"
            rgba="0.67 0.38 0.17 1"
            contype="1" conaffinity="1" friction="3.0 0.3 0.01" condim="4"
            solref="0.005 1" solimp="0.95 0.99 0.001"/>
      
      <site name="cup_center" pos="0 0 0" size="0.008" rgba="0.9 0.15 0.15 0"/>
      <site name="cup_hover_target" pos="0 0 0.10" size="0.015" rgba="0.2 0.8 0.35 0"/>
    </body>

    <body name="plate" pos="0.6 0.10 0.423">
      <freejoint/>
      <inertial pos="0 0 0" mass="0.18" diaginertia="0.00035 0.00035 0.0006"/>
      <geom type="cylinder" size="0.09 0.012" material="plate_white" friction="0.7 0.05 0.05"/>
    </body>
  </worldbody>
</mujoco>
